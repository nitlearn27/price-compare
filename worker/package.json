{
  "name": "price-compare-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Workers (TypeScript) port of the price-compare backend — Hono + @langchain/langgraph. Runs the agent, hub-spoke search, cart, and serves the Vite frontend as static assets.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@langchain/core": "^1.2.3",
    "@langchain/langgraph": "^1.4.8",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.6",
    "@cloudflare/workers-types": "^5.20260718.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
