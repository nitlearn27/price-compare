# ── Salesforce (OAuth 2.0 Client Credentials Flow) ──────────────────────────
SF_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=https://<your-domain>.my.salesforce.com/services/data/v60.0/sobjects/Product__c/
SF_API_VERSION=60.0
SF_QUERY_LIMIT=200
SF_RESULTS_PER_SOURCE=3

# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b

# ── App ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# ── Product refresh triggers (fire-and-forget HTTPS, no auth) ────────────────
# Endpoints triggered when the user says "refresh products for Amazon/Flipkart".
REFRESH_AMAZON_URL=
REFRESH_FLIPKART_URL=
REFRESH_ORDERS=2          # POST body sent to both endpoints: {"orders": <n>}

# ── Flipkart live keyword search (catalog fallback) ──────────────────────────
# Called when a product search finds nothing in the Salesforce catalog.
# GET ?name=<product> → returns Flipkart products as JSON.
SEARCH_PRODUCT_FLIPKART_URL=

# ── Recommendation engine ("next purchase" insights) ─────────────────────────
# External service the "Recommendations" drawer calls. Override to point at a
# different deployment; defaults to the production Railway endpoint.
RECOMMENDATION_API_URL=https://insight-generation-production.up.railway.app/api/insights/next-purchase

# ── Cart checkout (bulk order submission) ────────────────────────────────────
# External purchasing API the cart "Submit Order" button posts to.
# Body: {"products": ["Amul Gold Milk", "Aashirvaad Atta 5kg"]}
CART_FLIPKART_URL=https://purchase-history-production.up.railway.app/api/cart
# CART_AMAZON_URL=        # to be wired later

# ── Image Search (Gemini & OpenRouter fallbacks) ─────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_FALLBACK_MODEL=openrouter/free

# ── DeepSeek (primary chat/agent model; OpenAI-compatible API) ────────────────
# Drives the agentic loop; OpenRouter (above) is the automatic per-call fallback.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Agent guardrails (optional overrides; defaults shown) ─────────────────────
# Keep the tool-use loop bounded in iterations and tokens.
# AGENT_MAX_STEPS=6
# AGENT_MAX_OUTPUT_TOKENS=1024
# AGENT_TOKEN_BUDGET=20000
# AGENT_MAX_TOOL_CALLS_PER_STEP=4
# AGENT_HISTORY_LIMIT=30
# Hub-spoke aggregator: per-spoke timeout in seconds (slow sources are dropped).
# AGGREGATOR_SPOKE_TIMEOUT=25.0
# Annotate live results with the user's purchase history (restock/frequent).
# AGGREGATOR_ENRICH_HISTORY=true
# AGGREGATOR_HISTORY_DAYS=90
# Tiered fan-out: hit live store websites only when the catalog returns fewer
# than this many results (1 = skip live whenever the catalog has any match).
# AGGREGATOR_MIN_CATALOG_RESULTS=1
