# ── Salesforce (OAuth 2.0 Client Credentials Flow) ──────────────────────────
SF_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_ENDPOINT=https://<your-domain>.my.salesforce.com/services/data/v60.0/sobjects/Product__c/
SF_API_VERSION=60.0
SF_QUERY_LIMIT=200
SF_RESULTS_PER_SOURCE=3

# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b

# ── App ──────────────────────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# ── Product refresh triggers (fire-and-forget HTTPS, no auth) ────────────────
# Endpoints triggered when the user says "refresh products for Amazon/Flipkart".
REFRESH_AMAZON_URL=
REFRESH_FLIPKART_URL=
REFRESH_ORDERS=2          # POST body sent to both endpoints: {"orders": <n>}

# ── Recommendation engine ("next purchase" insights) ─────────────────────────
# External service the "Recommendations" drawer calls. Override to point at a
# different deployment; defaults to the production Railway endpoint.
RECOMMENDATION_API_URL=https://insight-generation-production.up.railway.app/api/insights/next-purchase
